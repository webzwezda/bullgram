{
  "name": "bullgram-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Управление подписками Bullgram (Backend)",
  "scripts": {
    "deploy": "DEPLOY_HOST=${DEPLOY_HOST:?required} rsync -avz --delete --exclude='node_modules' --exclude='.git' --exclude='_site' --exclude='.env' --exclude='.env.backup-*' --exclude='logs' --exclude='uploads' ./ \"${DEPLOY_USER:-root}@${DEPLOY_HOST}\":/var/www/backend/",
    "pull": "DEPLOY_HOST=${DEPLOY_HOST:?required} rsync -avz --delete --exclude='node_modules' --exclude='.git' --exclude='_site' --exclude='.env' --exclude='.env.backup-*' --exclude='logs' --exclude='uploads' \"${DEPLOY_USER:-root}@${DEPLOY_HOST}\":/var/www/backend/ ./",
    "test:autopost": "node test/test-autopost-timezone.js && node test/test-autopost-tz-bounds.js && node test/test-autopost-queue.js && node test/test-autopost-tier.js && node test/test-autopost-reactions.js && node test/test-autopost-bestof.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.4",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "socks-proxy-agent": "^9.0.0",
    "sqlite3": "^6.0.1",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22"
  }
}
