# =============================================================================
# Bullgram backend — environment template.
# Copy to backend/.env and fill in real values. Never commit the real .env.
# =============================================================================


# ---- Required boot contract -----------------------------------------------

# Self-hosted or cloud Supabase. Backend uses service-role key — full access.
SUPABASE_URL=https://your-supabase-host
SUPABASE_SERVICE_KEY=your-service-role-key

# Direct Postgres connection (used by ad-hoc migration scripts; not for runtime).
# Falls back to SUPABASE_URL parsing if not set in some scripts.
# Format: postgresql://<user>:<password>@<host>:5432/<db>
DATABASE_URL=
SUPABASE_DB_URL=

# 32-byte secret for at-rest encryption of Telegram sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-32-byte-secret


# ---- Telegram API credentials ---------------------------------------------

# Get at https://my.telegram.org → API Development Tools.
# These are project-level, not per-account.
TG_API_ID=123456
TG_API_HASH=your-telegram-api-hash


# ---- HTTP / origins -------------------------------------------------------

PORT=3000

# Public origin of the admin-v2 frontend (for CORS, webhook callbacks, etc.)
PUBLIC_APP_ORIGIN=https://your-domain.example
# Public origin of the public site-v2 frontend.
PUBLIC_API_ORIGIN=https://your-domain.example
# Base URL the official bot uses to register webhooks. Usually same as PUBLIC_APP_ORIGIN.
OFFICIAL_BOT_WEBHOOK_ORIGIN=https://your-domain.example
# Backend's own public base URL (used for self-references from jobs).
BACKEND_URL=https://your-domain.example

# Public IP bound to the network interface managed proxies listen on.
# Find with: `ip -4 addr show <INTERFACE>` on the prod server.
MANAGED_PROXY_PUBLIC_HOST=your-server-public-ip

# Managed proxy reconciliation job. Defaults are safe.
MANAGED_PROXY_RECONCILE_ENABLED=true
MANAGED_PROXY_RECONCILE_INTERVAL_MS=60000


# ---- Feature flags: userbot automation ------------------------------------
# All risky userbot scenarios are OFF by default. Enable each one explicitly.

# Manual DM from admin UI.
USERBOT_DM_ENABLED=false

# Background watcher of userbot inbox (fully off by default).
USERBOT_INBOX_WATCH_ENABLED=false

# Retention reminder fallback via userbot DM.
USERBOT_RETENTION_DM_ENABLED=false

# Auto-kick fallback via userbot when official bot cannot kick.
USERBOT_AUTO_KICK_FALLBACK_ENABLED=false

# DM after auto-kick via userbot.
USERBOT_AUTO_KICK_DM_ENABLED=false

# Userbot-based broadcasts.
USERBOT_BROADCAST_ENABLED=false

# Userbot-center tuning (safe defaults).
USERBOT_CENTER_ADMIN_CHECK_DELAY_MS=1500
USERBOT_CENTER_DIALOG_LIMIT=100
USERBOT_HEALTH_CONNECT_TIMEOUT_MS=15000
USERBOT_HEALTH_INSPECT_TIMEOUT_MS=20000


# ---- Restricted userbot cleanup -------------------------------------------

# Restricted userbots (SpamBot-confirmed) auto-delete after quarantine window.
RESTRICTED_USERBOT_AUTO_DELETE_ENABLED=true
RESTRICTED_USERBOT_DELETE_AFTER_HOURS=72
RESTRICTED_USERBOT_CLEANUP_INTERVAL_MS=21600000


# ---- TON / crypto billing -------------------------------------------------
# Bullgram is crypto-only. All values come from your TON API provider.

# TonAPI (https://tonapi.io/) — used for wallet lookups and transaction parsing.
TONAPI_API_BASE=https://tonapi.io
TONAPI_KEY=

# TON reserve wallet — bulk-payout sender for referral settlement.
TON_RESERVE_API_BASE=
TON_RESERVE_DEPOSIT_ADDRESS=
TON_RESERVE_TONAPI_KEY=
TON_RESERVE_JSONRPC_ENDPOINT=
TON_RESERVE_SENDER_ENDPOINT=
TON_RESERVE_API_KEY=
TON_RESERVE_WALLET_SECRET_FILE=

# TON payout confirmation polling.
TON_PAYOUT_CONFIRMATION_API_BASE=

# Referral payout flow (sender-side).
REFERRAL_PAYOUT_CONFIRMATION_ENABLED=false
REFERRAL_PAYOUT_SENDER_BATCH_LIMIT=10
REFERRAL_SETTLEMENT_RETRY_ENABLED=true


# ---- Crypto exchange rates ------------------------------------------------

# CoinGecko API for TON/RUB and TON/USD rates.
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINGECKO_API_KEY_HEADER=x-cg-pro-api-key
COINGECKO_TON_ID=the-open-network
CRYPTO_RATES_ENABLED=true
CRYPTO_RATES_INTERVAL_MS=300000
CRYPTO_RATE_MAX_AGE_MS=900000


# ---- Telegram Web integration (/app/telegram-web/) ------------------------
# MTProto relay bridge for in-browser Telegram client.
# When false: REST returns 503, WS upgrade rejected with 1008,
# "Открыть в Telegram Web" button hidden in admin-v2.
TELEGRAM_WEB_ENABLED=false

# Public WS URL the browser connects to. Defaults to /api/mtproto-bridge.
# Override only if backend is behind a different hostname.
# TELEGRAM_WEB_WS_URL=/api/mtproto-bridge

# Bridge health-check window (used by background watchdog).
TELEGRAM_WEB_HEALTH_INTERVAL_MS=30000
TELEGRAM_WEB_HEALTH_WINDOW_MS=300000
TELEGRAM_WEB_HEALTH_ERROR_THRESHOLD=5

# Used by the spike/smoke test scripts only. Set when running tests.
# BRIDGE_WS_URL=ws://localhost:8765


# ---- Misc / observability -------------------------------------------------

# Autoposter log level: debug | info | warn | error
AUTOPST_LOG_LEVEL=info

# Set to production on the prod server.
NODE_ENV=development


# ---- TON Connect 2.0 (admin-v2 crypto checkout) ---------------------------
# Required: EQ/UQ wallet that receives platform-tier upgrade payments
# (separate from seller's payment_settings.ton_wallet).
PLATFORM_TON_WALLET=

# Required: public site URL used in the TON Connect manifest.
# Wallet reads this when user clicks the connect button.
PUBLIC_SITE_URL=https://bullgram.io

# Optional: icon shown in wallet connection modal.
# Defaults to ${PUBLIC_SITE_URL}/icon-256.png
# TONCONNECT_MANIFEST_ICON_URL=

# Optional: TonAPI base URL. Use https://testnet.tonapi.io for testnet.
TONCONNECT_TONAPI_BASE=https://tonapi.io

# Optional: how long backend polls TonAPI before giving up (default 20 × 3s = 60s).
TONCONNECT_VERIFY_MAX_ATTEMPTS=20
TONCONNECT_VERIFY_INTERVAL_MS=3000

# Optional: background auto-detection of pending TON invoice payments.
# Cron polls each seller's ton_wallet on TonAPI, matches by memo+amount, and
# activates the subscription without the buyer clicking "Проверить оплату".
INVOICE_AUTODETECT_ENABLED=true
INVOICE_AUTODETECT_INTERVAL_MS=30000

# Optional: TON/RUB rate used to convert BILLING_NORMAL_PRICE_RUB to TON amount.
# Update manually when TON price moves significantly.
TON_TON_RUB_RATE=200

