# Required boot contract
SUPABASE_URL=https://your-supabase-host
SUPABASE_SERVICE_KEY=your-service-role-key
ENCRYPTION_KEY=replace-with-32-byte-secret

# Required for live Telegram and userbot flows
TG_API_ID=123456
TG_API_HASH=your-telegram-api-hash

# Optional runtime
PORT=3000
PUBLIC_APP_ORIGIN=https://bullrun.ru
OFFICIAL_BOT_WEBHOOK_ORIGIN=https://bullrun.ru
MANAGED_PROXY_PUBLIC_HOST=193.23.197.169

# BullRun platform billing for Normal plan
ROBOKASSA_ENABLED=false
ROBOKASSA_TEST_MODE=true
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD_1=
ROBOKASSA_PASSWORD_2=
BILLING_NORMAL_PRICE_RUB=900
BILLING_NORMAL_DURATION_DAYS=365
BILLING_PENDING_ORDER_TTL_MINUTES=30

# Feature flags: all risky userbot automation should stay off by default
USERBOT_DM_ENABLED=false
USERBOT_BROADCAST_ENABLED=false
USERBOT_RETENTION_DM_ENABLED=false
USERBOT_AUTO_KICK_DM_ENABLED=false
USERBOT_AUTO_KICK_FALLBACK_ENABLED=false
USERBOT_INBOX_WATCH_ENABLED=false

# Restricted userbot cleanup
RESTRICTED_USERBOT_AUTO_DELETE_ENABLED=true
RESTRICTED_USERBOT_DELETE_AFTER_HOURS=72
RESTRICTED_USERBOT_CLEANUP_INTERVAL_MS=21600000
