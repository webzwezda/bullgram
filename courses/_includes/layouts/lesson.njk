---
layout: layouts/base.njk
---
{% set currentCourse = courses | courseBySlug(course) %}
{% set lessons = collections.lessons | courseLessons(course) %}
{% set previous = lessons | previousLesson(page.url) %}
{% set next = lessons | nextLesson(page.url) %}

<article class="course-canvas course-article">
  <div class="course-article__header">
    <a class="course-back-link" href="{{ ('/' + course + '/') | coursesPath }}">← {{ currentCourse.label }}</a>
    <div class="course-meta">
      <span>Урок {{ order }}</span>
      <span>{{ date | readableDate }}</span>
    </div>
    <h1>{{ title }}</h1>
    {% if description %}
      <p class="course-lead">{{ description }}</p>
    {% endif %}
    {% if image %}
      <figure class="course-article__cover">
        <img src="{{ image | coursesPath }}" alt="{{ imageAlt or title }}" loading="eager" decoding="async">
        {% if imageCaption %}
          <figcaption>{{ imageCaption }}</figcaption>
        {% endif %}
      </figure>
    {% endif %}
  </div>

  <div class="course-prose">
    {{ content | safe }}
  </div>

  <nav class="course-lesson-pager" aria-label="Навигация уроков">
    {% if previous %}
      <a href="{{ previous.url | coursesPath }}">
        <span>Предыдущий урок</span>
        <strong>{{ previous.data.title }}</strong>
      </a>
    {% else %}
      <span></span>
    {% endif %}
    {% if next %}
      <a href="{{ next.url | coursesPath }}">
        <span>Следующий урок</span>
        <strong>{{ next.data.title }}</strong>
      </a>
    {% endif %}
  </nav>
</article>
