---
layout: layouts/base.njk
---
{% set currentCourse = courses | courseBySlug(activeCourse) %}
{% set lessons = collections.lessons | courseLessons(activeCourse) %}

<section class="course-canvas course-overview">
  <div class="course-hero">
    <div class="course-kicker">{{ currentCourse.eyebrow }}</div>
    <h1>{{ currentCourse.title }}</h1>
    <p>{{ currentCourse.description }}</p>
  </div>

  <div class="course-summary-grid">
    <div>
      <span>Формат</span>
      <strong>Бесплатный вводный курс</strong>
    </div>
    <div>
      <span>Уроков</span>
      <strong>{{ lessons.length }}</strong>
    </div>
    <div>
      <span>Цель</span>
      <strong>Понять рынок до первых действий</strong>
    </div>
  </div>

  <div class="course-lesson-list">
    {% for lesson in lessons %}
      <a class="course-row" href="{{ lesson.url | coursesPath }}">
        <span class="course-row__number">{{ lesson.data.order }}</span>
        <span class="course-row__body">
          <strong>{{ lesson.data.title }}</strong>
          <small>{{ lesson.data.description }}</small>
        </span>
      </a>
    {% endfor %}
  </div>
</section>
