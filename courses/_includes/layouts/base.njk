<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set pageTitle = title or site.title %}
    {% set pageDescription = description or site.description %}
    {% set pageUrl = page.url | absoluteCoursesUrl %}
    {% set pageImage = image or false %}
    {% if pageImage %}
      {% set pageImageUrl = pageImage | absoluteCoursesUrl %}
    {% endif %}
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ pageDescription }}">
    <meta name="robots" content="{{ robots or 'max-image-preview:large' }}">
    <link rel="canonical" href="{{ pageUrl }}">
    <meta property="og:type" content="{% if layout == 'layouts/lesson.njk' %}article{% else %}website{% endif %}">
    <meta property="og:url" content="{{ pageUrl }}">
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:description" content="{{ pageDescription }}">
    {% if pageImage %}
    <meta property="og:image" content="{{ pageImageUrl }}">
    {% if imageAlt %}
    <meta property="og:image:alt" content="{{ imageAlt }}">
    {% endif %}
    {% endif %}
    <meta property="og:site_name" content="{{ site.title }}">
    <meta name="twitter:card" content="{% if pageImage %}summary_large_image{% else %}summary{% endif %}">
    <meta name="twitter:title" content="{{ pageTitle }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    {% if pageImage %}
    <meta name="twitter:image" content="{{ pageImageUrl }}">
    {% if imageAlt %}
    <meta name="twitter:image:alt" content="{{ imageAlt }}">
    {% endif %}
    {% endif %}

    {% if layout == 'layouts/lesson.njk' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": {{ pageTitle | json | safe }},
      "description": {{ pageDescription | json | safe }},
      "url": {{ pageUrl | json | safe }},
      {% if pageImage %}
      "image": {{ pageImageUrl | json | safe }},
      {% endif %}
      "datePublished": {{ date | isoDate | json | safe }},
      "dateModified": {{ (updated or date) | isoDate | json | safe }},
      "learningResourceType": "lesson",
      "inLanguage": "ru",
      "provider": {
        "@type": "Organization",
        "name": "BullRun",
        "url": {{ site.url | json | safe }}
      }
    }
    </script>
    {% elif layout == 'layouts/course.njk' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Course",
      "name": {{ pageTitle | json | safe }},
      "description": {{ pageDescription | json | safe }},
      "url": {{ pageUrl | json | safe }},
      "inLanguage": "ru",
      "provider": {
        "@type": "Organization",
        "name": "BullRun",
        "url": {{ site.url | json | safe }}
      }
    }
    </script>
    {% endif %}

    <link rel="stylesheet" href="{{ '/styles/courses.css' | coursesPath }}?v={{ site.assetVersion }}">
  </head>
  <body>
    {% set activeCourseData = courses | courseBySlug(activeCourse or course) %}
    {% if activeCourseData %}
      {% set sidebarLessons = collections.lessons | courseLessons(activeCourseData.slug) %}
    {% endif %}
    <div class="course-shell">
      <header class="course-mobile-header">
        <div>
          <div class="course-kicker">BullRun</div>
          <div class="course-mobile-title">Курсы</div>
        </div>
        <button class="course-menu-button" type="button" aria-controls="course-sidebar" aria-expanded="false" aria-label="Открыть меню" data-course-menu-toggle>
          <span></span>
          <span></span>
          <span></span>
        </button>
      </header>

      <button class="course-overlay" type="button" aria-label="Закрыть меню" data-course-menu-overlay></button>

      <aside class="course-sidebar" id="course-sidebar" aria-label="Навигация курсов" data-course-sidebar>
        <div class="course-home-wrap">
          <a class="course-home-card" href="/">
            <span class="course-home-card__mark">BR</span>
            <span class="course-home-card__label">На главную сайта</span>
          </a>
        </div>

        <nav class="course-nav">
          <div class="course-nav__section">Курсы</div>
          <div class="course-nav__items">
            {% for item in courses %}
              <a class="course-nav-link{% if activeCourseData and activeCourseData.slug == item.slug %} course-nav-link--active{% endif %}" href="{{ ('/' + item.slug + '/') | coursesPath }}">
                <span>{{ item.label }}</span>
                <small>{{ item.eyebrow }}</small>
              </a>
            {% endfor %}
          </div>

          {% if sidebarLessons and sidebarLessons.length %}
            <div class="course-nav__section course-nav__section--lessons">Уроки</div>
            <div class="course-nav__items">
              {% for lesson in sidebarLessons %}
                <a class="course-lesson-link{% if page.url == lesson.url %} course-lesson-link--active{% endif %}" href="{{ lesson.url | coursesPath }}">
                  <span>{{ lesson.data.order }}</span>
                  <strong>{{ lesson.data.title }}</strong>
                </a>
              {% endfor %}
            </div>
          {% endif %}
        </nav>

        <div class="course-sidebar__footer">
          <a href="/blog/">Блог</a>
          <a href="/app">Войти в BullRun</a>
        </div>
      </aside>

      <main class="course-main">
        {{ content | safe }}
      </main>
    </div>

    <script>
      (function() {
        var toggle = document.querySelector('[data-course-menu-toggle]');
        var overlay = document.querySelector('[data-course-menu-overlay]');
        var sidebar = document.querySelector('[data-course-sidebar]');
        if (!toggle || !overlay || !sidebar) return;

        function setMenuOpen(isOpen) {
          document.body.classList.toggle('course-menu-open', isOpen);
          toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          toggle.setAttribute('aria-label', isOpen ? 'Закрыть меню' : 'Открыть меню');
        }

        toggle.addEventListener('click', function() {
          setMenuOpen(!document.body.classList.contains('course-menu-open'));
        });
        overlay.addEventListener('click', function() {
          setMenuOpen(false);
        });
        sidebar.querySelectorAll('a').forEach(function(link) {
          link.addEventListener('click', function() {
            setMenuOpen(false);
          });
        });
        document.addEventListener('keydown', function(event) {
          if (event.key === 'Escape') setMenuOpen(false);
        });
        window.addEventListener('resize', function() {
          if (window.matchMedia('(min-width: 901px)').matches) setMenuOpen(false);
        });
      })();
    </script>
  </body>
</html>
